# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is gitignored.

# TMDB — get a free key at https://developer.themoviedb.org
TMDB_API_KEY=your_tmdb_api_key_here

# Supabase — create a free project at https://supabase.com
# Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Settings → API → anon public key
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Optional — Upstash Redis for distributed rate limiting
# Leave blank to use in-memory (fine for single-instance Render free tier)
REDIS_URL=

# CORS — comma-separated list of allowed origins
# For local dev: http://localhost:3000
# For production: https://your-app.vercel.app
ALLOWED_ORIGINS=["http://localhost:3000"]

# Set to "production" on Render
ENVIRONMENT=development
